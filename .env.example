# Copy this file to .env and fill in your values. Never commit .env.

# --- MCP authentication (dual mode: OIDC preferred + optional API key fallback) ---
# Auth mode: oidc_preferred (default) or api_key_only
# AUTH_MODE=oidc_preferred
# Allow static API key when no Bearer token (set false in production for SSO-only)
# AUTH_ALLOW_API_KEY_FALLBACK=true

# When using API key (legacy or fallback): required if AUTH_MODE=api_key_only or fallback enabled
MCP_API_KEY=your-secure-api-key

# OIDC (provider-agnostic: Azure AD, Okta, Ping, etc.)
# Required for SSO: issuer URL (e.g. https://login.microsoftonline.com/<tenant>/v2.0)
# OIDC_ISSUER_URL=https://your-tenant.b2clogin.com/your-tenant.onmicrosoft.com/v2.0
# Optional: override discovery URL (default: {OIDC_ISSUER_URL}/.well-known/openid-configuration)
# OIDC_DISCOVERY_URL=
# Audience and client ID for token validation
# OIDC_AUDIENCE=your-client-id-or-api-identifier
# OIDC_CLIENT_ID=your-client-id
# OIDC_SCOPES=openid profile email
# Claim names for email / username (defaults: email, preferred_username)
# OIDC_EMAIL_CLAIM=email
# OIDC_USERNAME_CLAIM=preferred_username
# Clock skew tolerance in seconds for expiry validation
# OIDC_CLOCK_SKEW_SECONDS=60

# Optional: when using devtunnel/ngrok, set the public URL so the SSE "endpoint" event uses it
# MCP_PUBLIC_URL=https://your-tunnel-id.devtunnels.ms

# Optional: extra CORS origins (comma-separated), e.g. for MCP Inspector behind another origin
# CORS_ORIGINS=http://localhost:8080

# LumApps API — Option 1: Client credentials (production)
# Read app (all.read): used for search, content, directory, inspect, search_site
# Prefer LUMAPPS_READ_* in Kubernetes/enterprise; legacy LUMAPPS_CLIENT_* also supported
LUMAPPS_READ_CLIENT_ID=your-lumapps-read-client-id
LUMAPPS_READ_CLIENT_SECRET=your-lumapps-read-client-secret
# Legacy names (used if READ_* above are not set)
# LUMAPPS_CLIENT_ID=your-lumapps-client-id
# LUMAPPS_CLIENT_SECRET=your-lumapps-client-secret

# Admin app (all.admin): required for modification tools (update_global_css, update_widget_style)
# Create a second OAuth app in LumApps with all.admin scope; omit for read-only deployments
# LUMAPPS_ADMIN_CLIENT_ID=your-admin-client-id
# LUMAPPS_ADMIN_CLIENT_SECRET=your-admin-client-secret

# LumApps API — Option 2: Token direct (tests only); if set, used instead of client_id/secret
# LUMAPPS_ACCESS_TOKEN=your-bearer-token

LUMAPPS_ORG_ID=your-organization-id
LUMAPPS_HAUSSMANN_CELL=https://go-cell-003.beta.api.lumapps.com
SITE_BASE_URL=https://sites.lumapps.com

# --- RBAC (user-level role checks for Content/Structural tools) ---
# RBAC_ENABLED=true
# Claim name for role/groups (e.g. groups, roles)
# RBAC_ROLE_CLAIM=groups
# Patterns: {site_id} replaced by target site; comma-separated. Global admin: use literal * (e.g. lumapps:site:*:admin)
# RBAC_ADMIN_PATTERNS=lumapps:site:{site_id}:admin
# RBAC_CONTRIBUTOR_PATTERNS=lumapps:site:{site_id}:contributor,lumapps:site:{site_id}:admin
# RBAC_GLOBAL_ADMIN_PATTERNS=lumapps:site:*:admin,lumapps:global:admin
# Deny Content/Structural tools when authenticated with API key only (no OIDC identity)
# RBAC_DENY_API_KEY_FOR_NON_READ=true
# Content -> site resolution cache (TTL seconds, max entries)
# RBAC_CONTENT_SITE_CACHE_TTL_SECONDS=300
# RBAC_CONTENT_SITE_CACHE_MAX_SIZE=500

# App
LOG_LEVEL=INFO
MAX_SEARCH_RESULTS=5
