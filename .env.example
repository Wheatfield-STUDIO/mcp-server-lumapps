# Copy this file to .env and fill in your values. Never commit .env.

# Required: API key for MCP clients (Cursor, Copilot Studio, MCP Inspector)
MCP_API_KEY=your-secure-api-key

# Optional: when using devtunnel/ngrok, set the public URL so the SSE "endpoint" event uses it
# MCP_PUBLIC_URL=https://your-tunnel-id.devtunnels.ms

# Optional: extra CORS origins (comma-separated), e.g. for MCP Inspector behind another origin
# CORS_ORIGINS=http://localhost:8080

# LumApps API — Option 1: Client credentials (production)
# Read app (all.read): used for search, content, directory, inspect, search_site
LUMAPPS_CLIENT_ID=your-lumapps-client-id
LUMAPPS_CLIENT_SECRET=your-lumapps-client-secret

# Admin app (all.admin): required for modification tools (update_global_css, update_widget_style)
# Create a second OAuth app in LumApps with all.admin scope; omit for read-only deployments
# LUMAPPS_ADMIN_CLIENT_ID=your-admin-client-id
# LUMAPPS_ADMIN_CLIENT_SECRET=your-admin-client-secret

# LumApps API — Option 2: Token direct (tests only); if set, used instead of client_id/secret
# LUMAPPS_ACCESS_TOKEN=your-bearer-token

LUMAPPS_ORG_ID=your-organization-id
LUMAPPS_HAUSSMANN_CELL=https://go-cell-003.beta.api.lumapps.com
SITE_BASE_URL=https://sites.lumapps.com

# App
LOG_LEVEL=INFO
MAX_SEARCH_RESULTS=5
